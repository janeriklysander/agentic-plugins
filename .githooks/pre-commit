#!/usr/bin/env bash
# Pre-commit hook: require plugin.json version bump when plugin files change.
# For each plugin with staged changes, checks that plugin.json is also staged
# with a version diff. Exits non-zero if a version bump is missing.

set -euo pipefail

changed_plugins=$(git diff --cached --name-only | grep '^plugins/' | cut -d/ -f2 | sort -u)

if [ -z "$changed_plugins" ]; then
  exit 0
fi

failed=0

for plugin in $changed_plugins; do
  manifest="plugins/$plugin/.claude-plugin/plugin.json"

  if [ ! -f "$manifest" ]; then
    continue
  fi

  # Check if plugin.json is in the staged changes
  if ! git diff --cached --name-only | grep -q "^${manifest}$"; then
    # Check if it was modified but not staged
    if git diff --name-only | grep -q "^${manifest}$"; then
      echo "ERROR: Plugin '$plugin' — version bump in $manifest is not staged."
      echo "       Run: git add $manifest"
    else
      echo "ERROR: Plugin '$plugin' has staged changes but version in $manifest was not bumped."
      echo "       Bump the version in $manifest before committing."
    fi
    failed=1
    continue
  fi

  # Check if the version field actually changed
  old_version=$(git show HEAD:"$manifest" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*: *"\(.*\)".*/\1/')
  new_version=$(git diff --cached --staged -p -- "$manifest" | grep '^\+.*"version"' | head -1 | sed 's/.*: *"\(.*\)".*/\1/')

  if [ -n "$old_version" ] && [ -z "$new_version" ]; then
    echo "ERROR: Plugin '$plugin' has staged changes but version in $manifest is unchanged."
    echo "       Current version: $old_version — bump it before committing."
    failed=1
  fi
done

if [ "$failed" -ne 0 ]; then
  echo ""
  echo "Hint: use semver — patch for fixes, minor for features, major for breaking changes."
  exit 1
fi
